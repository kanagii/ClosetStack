<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->

    <style name="Base.Theme.ClosetStack" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:statusBarColor">@color/dark_navy</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorSurface">@color/dark_navy</item>
        <item name="colorSurfaceContainer">@color/dark_navy</item>
        <item name="colorSurfaceVariant">@color/dark_navy</item>
        <item name="elevationOverlayEnabled">false</item>

    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">true</item>
    </style>

    <style name="Theme.ClosetStack" parent="Base.Theme.ClosetStack" />

    <style name="BottomSheetDarkTheme" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/DarkBottomSheetStyle</item>
    </style>

    <style name="DarkBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">#1E1E1E</item>
    </style>

    <!-- App Themes -->
    <style name="Theme.ClosetStack.PaperZine" parent="Base.Theme.ClosetStack">
        <item name="colorPrimary">@color/paper_primary</item>
        <item name="colorSecondary">@color/paper_secondary</item>
        <item name="android:windowBackground">@color/paper_bg</item>
    </style>

    <style name="Theme.ClosetStack.StreetHeat" parent="Base.Theme.ClosetStack">
        <item name="colorPrimary">@color/street_primary</item>
        <item name="colorSecondary">@color/street_secondary</item>
        <item name="android:windowBackground">@color/street_bg</item>
    </style>

    <style name="Theme.ClosetStack.Midnight" parent="Base.Theme.ClosetStack">
        <item name="colorPrimary">@color/midnight_primary</item>
        <item name="colorSecondary">@color/midnight_secondary</item>
        <item name="android:windowBackground">@color/midnight_bg</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <style name="Theme.ClosetStack.BubbleGum" parent="Base.Theme.ClosetStack">
        <item name="colorPrimary">@color/bubble_primary</item>
        <item name="colorSecondary">@color/bubble_secondary</item>
        <item name="android:windowBackground">@color/bubble_bg</item>
    </style>

    <style name="Theme.ClosetStack.OriginalNavy" parent="Base.Theme.ClosetStack">
        <item name="android:windowBackground">@color/dark_navy</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorSecondary">#888888</item>
    </style>
    <style name="Theme.ClosetStack.DefaultDark" parent="Base.Theme.ClosetStack">
        <item name="android:windowBackground">@color/default_dark_bg</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="colorPrimary">#FFFFFF</item>
        <item name="colorSecondary">#888888</item>
    </style>

</resources>