<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:paddingBottom="24dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="#555555" />

    <!-- Header: title + close -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Profile"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivEditBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#AAAAAA" />

    </LinearLayout>

    <!-- Scrollable edit fields -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Display Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISPLAY NAME"
                android:textColor="#CCCCDD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEditDisplayName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_dark"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="Your name"
                android:text="Vanessa Kung"
                android:textColor="#FFFFFF"
                android:textColorHint="#888899"
                android:textSize="14sp"
                android:inputType="textPersonName"
                android:singleLine="true" />

            <!-- Username -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USERNAME"
                android:textColor="#CCCCDD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEditUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_dark"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="@username"
                android:text="vanessa_kung"
                android:textColor="#FFFFFF"
                android:textColorHint="#888899"
                android:textSize="14sp"
                android:inputType="textNoSuggestions"
                android:singleLine="true" />

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCATION"
                android:textColor="#CCCCDD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEditLocation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_dark"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="City, Country"
                android:text="Philippines"
                android:textColor="#FFFFFF"
                android:textColorHint="#888899"
                android:textSize="14sp"
                android:inputType="text"
                android:singleLine="true" />

            <!-- Bio / About -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BIO"
                android:textColor="#CCCCDD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input_dark"
                android:padding="14dp"
                android:hint="Write something about yourself"
                android:text="Fashion and Styling Enthusiast"
                android:textColor="#FFFFFF"
                android:textColorHint="#888899"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:maxLines="4"
                android:gravity="top" />

            <!-- Interests -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INTERESTS"
                android:textColor="#CCCCDD"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etInterests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input_dark"
                android:padding="14dp"
                android:hint="#streetwear #hiphop"
                android:text="#Core  #FreeNovaJeans  #ForTheStreets&#10;#StreetWear  #hiphop"
                android:textColor="#FFFFFF"
                android:textColorHint="#888899"
                android:textSize="13sp"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top" />

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Save Profile"
                android:textColor="#121212"
                android:textStyle="bold"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>