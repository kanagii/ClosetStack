<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy"
    tools:context=".CreatePostActivity">

    <!-- Top Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_navy"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/ivBackCreatePost"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="create a post"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/ivBackCreatePost"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="40dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp">

            <!-- Photo Upload Area -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPhotoUpload"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <!-- Empty state -->
                <LinearLayout
                    android:id="@+id/llPhotoPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:src="@drawable/ic_camera_placeholder"
                        app:tint="#888888" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="snap it, or upload it"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="take a photo or upload from gallery"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Selected photo -->
                <ImageView
                    android:id="@+id/ivPostPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="Selected post photo" />

                <!-- Quiet ready badge -->
                <TextView
                    android:id="@+id/tvReplaceBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_replace_badge"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="ready"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:visibility="gone" />
            </androidx.cardview.widget.CardView>

            <!-- Camera / Gallery -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTakePhoto"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Camera"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#252535"
                    app:strokeColor="#3A3A55"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_camera_placeholder"
                    app:iconTint="#FFFFFF"
                    app:iconSize="16dp"
                    app:iconPadding="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickGallery"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="Gallery"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#252535"
                    app:strokeColor="#3A3A55"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_gallery"
                    app:iconTint="#FFFFFF"
                    app:iconSize="16dp"
                    app:iconPadding="6dp" />
            </LinearLayout>

            <!-- Description label row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="description"
                    android:textColor="#CCCCDD"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvCharCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 80"
                    android:textColor="#666677"
                    android:textSize="11sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etPostDescription"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_post_input"
                android:hint="e.g. street core fits only"
                android:textColorHint="#666677"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="text"
                android:maxLines="1"
                android:maxLength="80"
                android:imeOptions="actionDone"
                android:layout_marginBottom="28dp" />

            <!-- Save Post button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePost"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Post"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:text="your post will show up on home and in your profile"
                android:textColor="#666677"
                android:textSize="11sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>