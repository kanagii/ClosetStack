<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose your vibe"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemeOriginal"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Original Navy"
        android:textColor="#FFFFFF"
        app:backgroundTint="@color/dark_navy"
        app:strokeColor="#555555"
        app:strokeWidth="1dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemeDefaultDark"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Default Dark"
        android:textColor="#FFFFFF"
        app:backgroundTint="@color/default_dark_bg"
        app:strokeColor="#555555"
        app:strokeWidth="1dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemeBubbleGum"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Bubble Gum"
        android:textColor="#FFFFFF"
        app:backgroundTint="@color/bubble_secondary"
        app:strokeColor="#FFB7D1"
        app:strokeWidth="1dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemeCustom"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Customize Your Own"
        android:textColor="?android:attr/textColorPrimary"
        app:backgroundTint="?attr/colorSurface"
        app:strokeColor="?attr/colorPrimary"
        app:strokeWidth="2dp"
        android:layout_marginBottom="16dp"/>

</LinearLayout>