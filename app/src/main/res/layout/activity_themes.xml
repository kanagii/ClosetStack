<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose your vibe"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemePaperZine"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Paper Zine"
        android:textColor="@color/black"
        app:backgroundTint="@color/paper_primary"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemeStreetHeat"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Street Heat"
        android:textColor="@color/black"
        app:backgroundTint="@color/street_primary"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemeMidnight"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Midnight"
        android:textColor="@color/white"
        app:backgroundTint="@color/midnight_bg"
        app:strokeColor="@color/midnight_primary"
        app:strokeWidth="2dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemeBubbleGum"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="Bubble Gum"
        android:textColor="@color/black"
        app:backgroundTint="@color/bubble_primary"
        android:layout_marginBottom="16dp"/>

</LinearLayout>