<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="18dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 2x2 collage with colored backgrounds -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:orientation="vertical">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="1.5dp">

                <FrameLayout
                    android:id="@+id/cellTopLeft"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="1.5dp"
                    android:background="#F5C842">
                    <ImageView
                        android:id="@+id/ivOutfitItem1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:src="@drawable/benchtee" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/cellTopRight"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#E05C5C">
                    <ImageView
                        android:id="@+id/ivOutfitItem2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:src="@drawable/relaxedpants" />
                </FrameLayout>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/cellBottomLeft"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="1.5dp"
                    android:background="#5B9BD5">
                    <ImageView
                        android:id="@+id/ivOutfitItem3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:src="@drawable/airforce" />

                    <!-- NO ACCESSORIES label -->
                    <TextView
                        android:id="@+id/tvNoAccessories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="#66000000"
                        android:gravity="center"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="NO ACCESSORIES"
                        android:textColor="#FFFFFF"
                        android:textSize="7sp"
                        android:letterSpacing="0.08"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/cellBottomRight"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#7DC47D">
                    <ImageView
                        android:id="@+id/ivOutfitItem4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside"
                        android:padding="6dp"
                        android:src="@drawable/adjustable_cap" />
                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Bottom info -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="10dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="#1E1E1E">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/tvOutfitDescription">

                <TextView
                    android:id="@+id/tvOutfitName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hype Boy"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvOutfitCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Casual"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginTop="1dp" />

            </LinearLayout>

            <!-- Item count badge -->
            <TextView
                android:id="@+id/tvOutfitDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4 items"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:background="@drawable/bg_badge_subtle"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>