<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <!-- Three images in a row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivRowPost1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_post1" />

        <ImageView
            android:id="@+id/ivRowPost2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_post2" />

        <ImageView
            android:id="@+id/ivRowPost3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scaleType="centerCrop"
            android:src="@drawable/img_post3" />

    </LinearLayout>

    <!-- Bottom row: ratings + menu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:gravity="center_vertical">

        <!-- Rating for post 1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_star_small"
                app:tint="@android:color/white" />
            <TextView
                android:id="@+id/tvRating1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.5"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- Rating for post 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_star_small"
                app:tint="@android:color/white" />
            <TextView
                android:id="@+id/tvRating2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.8"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- Rating for post 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_star_small"
                app:tint="@android:color/white" />
            <TextView
                android:id="@+id/tvRating3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4.2"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginStart="2dp" />
        </LinearLayout>

        <!-- Three dot menu -->
        <ImageView
            android:id="@+id/ivRowMenu"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_more_vert"
            android:alpha="0.6"
            android:layout_marginEnd="4dp" />

    </LinearLayout>

</LinearLayout>