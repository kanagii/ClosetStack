<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_navy"
    tools:context=".StyleCanvasActivity">

    <!-- Top Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_navy"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Style Canvas"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/ivBack"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="40dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <!-- Outfit Name Field -->
            <EditText
                android:id="@+id/etOutfitName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_input_dark"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="Outfit name (e.g. Hype Boy)"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:textStyle="bold"
                android:inputType="text" />

            <!-- Category Selector -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/llCanvasCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView android:id="@+id/tvCanvasCatCasual"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:layout_marginEnd="8dp" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:text="casual" android:textSize="12sp"
                        android:textColor="#000000" android:textStyle="bold"
                        android:background="@drawable/bg_category_selected" />

                    <TextView android:id="@+id/tvCanvasCatFormal"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:layout_marginEnd="8dp" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:text="formal" android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:background="@drawable/bg_category_unselected" />

                    <TextView android:id="@+id/tvCanvasCatBusiness"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:layout_marginEnd="8dp" android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:text="business" android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:background="@drawable/bg_category_unselected" />

                    <TextView android:id="@+id/tvCanvasCatStreet"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:gravity="center"
                        android:paddingStart="16dp" android:paddingEnd="16dp"
                        android:text="streetwear" android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:background="@drawable/bg_category_unselected" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Canvas Slots label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Style Outfit"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />

            <!-- 4 Slots: Top, Bottom, Shoes, Accessories -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Left column: Top + Accessories -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">

                    <!-- Top slot -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/slotTop"
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:layout_marginBottom="6dp"
                        app:cardBackgroundColor="#F5C842"
                        app:cardCornerRadius="12dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/ivSlotTop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:padding="8dp"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/layoutTopEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:background="@drawable/bg_dashed_border_light">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tops"
                                    android:textColor="#FFFFFF"
                                    android:textSize="9sp"
                                    android:gravity="center" />

                            </LinearLayout>

                            <!-- Active indicator ring -->
                            <View
                                android:id="@+id/ringSlotTop"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_slot_active"
                                android:visibility="visible" />

                            <ImageView
                                android:id="@+id/btnAiSuggestTop"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:background="@drawable/bg_icon_circle"
                                android:padding="6dp"
                                android:src="@drawable/ic_star_small"
                                app:tint="#121212"
                                android:contentDescription="AI Suggestion" />

                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Accessories slot -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/slotAccessories"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        app:cardBackgroundColor="#B07FD4"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/ivSlotAccessories"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:padding="8dp"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/layoutAccessoriesEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:background="@drawable/bg_dashed_border_light">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Accessories"
                                    android:textColor="#FFFFFF"
                                    android:textSize="9sp"
                                    android:gravity="center" />

                            </LinearLayout>

                            <View
                                android:id="@+id/ringSlotAccessories"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_slot_active"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/btnAiSuggestAccessories"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:background="@drawable/bg_icon_circle"
                                android:padding="6dp"
                                android:src="@drawable/ic_star_small"
                                app:tint="#121212"
                                android:contentDescription="AI Suggestion" />

                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Right column: Bottom + Shoes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Bottom slot -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/slotBottom"
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:layout_marginBottom="6dp"
                        app:cardBackgroundColor="#E05C5C"
                        app:cardCornerRadius="12dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/ivSlotBottom"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:padding="8dp"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/layoutBottomEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:background="@drawable/bg_dashed_border_light">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Bottoms"
                                    android:textColor="#FFFFFF"
                                    android:textSize="9sp"
                                    android:gravity="center" />

                            </LinearLayout>

                            <View
                                android:id="@+id/ringSlotBottom"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_slot_active"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/btnAiSuggestBottom"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:background="@drawable/bg_icon_circle"
                                android:padding="6dp"
                                android:src="@drawable/ic_star_small"
                                app:tint="#121212"
                                android:contentDescription="AI Suggestion" />

                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Shoes slot -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/slotShoes"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        app:cardBackgroundColor="#5BB5A2"
                        app:cardCornerRadius="12dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/ivSlotShoes"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerInside"
                                android:padding="8dp"
                                android:visibility="gone" />

                            <LinearLayout
                                android:id="@+id/layoutShoesEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:background="@drawable/bg_dashed_border_light">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Shoes"
                                    android:textColor="#FFFFFF"
                                    android:textSize="9sp"
                                    android:gravity="center" />

                            </LinearLayout>

                            <View
                                android:id="@+id/ringSlotShoes"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_slot_active"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/btnAiSuggestShoes"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="6dp"
                                android:background="@drawable/bg_icon_circle"
                                android:padding="6dp"
                                android:src="@drawable/ic_star_small"
                                app:tint="#121212"
                                android:contentDescription="AI Suggestion" />

                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <!-- Save / Reset Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveOutfit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Save Outfit"
                    android:textColor="#121212"
                    android:textStyle="bold"
                    app:backgroundTint="#FFFFFF"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetOutfit"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Reset"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#00000000"
                    app:strokeColor="#555555"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Add From Closet -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add From Closet"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- Slot filter tabs -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:id="@+id/llSlotFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/tvFilterAll"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:layout_marginEnd="8dp" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:text="All" android:textSize="12sp"
                        android:textColor="#000000" android:textStyle="bold"
                        android:background="@drawable/bg_category_selected" />

                    <TextView android:id="@+id/tvFilterTops"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:layout_marginEnd="8dp" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:text="Tops" android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:background="@drawable/bg_category_unselected" />

                    <TextView android:id="@+id/tvFilterBottoms"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:layout_marginEnd="8dp" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:text="Bottoms" android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:background="@drawable/bg_category_unselected" />

                    <TextView android:id="@+id/tvFilterShoes"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:layout_marginEnd="8dp" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:text="Shoes" android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:background="@drawable/bg_category_unselected" />

                    <TextView android:id="@+id/tvFilterAccessories"
                        android:layout_width="wrap_content" android:layout_height="30dp"
                        android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:text="Accessories" android:textSize="12sp"
                        android:textColor="#AAAAAA"
                        android:background="@drawable/bg_category_unselected" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Closet grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClosetForCanvas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_closet_clothing" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>